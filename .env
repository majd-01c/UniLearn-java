# SMS Verification Configuration
# Twilio Account Credentials
# Sign up at https://www.twilio.com to get these values
TWILIO_ACCOUNT_SID=AC8bf9b15c9ce605884758eea78717e3a8
TWILIO_AUTH_TOKEN=3e71e646646b8d17e12e77368abfe02a


# Twilio Verify Service (recommended for production)
# Leave empty to use direct Messaging API instead
# Create a Verify Service at https://console.twilio.com/develop/verify/services
TWILIO_VERIFY_SERVICE_SID=VA8ce5aa950736e9a7de62d5793bcc329a

# Twilio Messaging (used only if TWILIO_VERIFY_SERVICE_SID is empty)
# Your Twilio phone number (e.g., +1234567890)
TWILIO_FROM_NUMBER=+19785708276
TWILIO_TO_NUMBER=+21695488384

# OTP Configuration
# Time-to-live for OTP codes in seconds (default: 600 = 10 minutes)
OTP_TTL_SECONDS=600

# Maximum number of failed OTP verification attempts before lockout (default: 3)
OTP_MAX_ATTEMPTS=3

# Cooldown period between OTP resend requests in seconds (default: 60 = 1 minute)
OTP_RESEND_COOLDOWN_SECONDS=60

# DATABASE CONFIGURATION (if needed)
# Connection string for database with SMS tables
# DB_URL=jdbc:mysql://localhost:3306/unilearn
# DB_USER=root
# DB_PASSWORD=

# LOGGING
# SMS operations logging level (INFO, DEBUG, WARN)
# SMS_LOG_LEVEL=INFO

# SECURITY
# Enable audit logging for SMS operations (true/false)
SMS_AUDIT_LOGGING_ENABLED=true

# Feature flags
# Enable SMS verification requirement (true/false)
SMS_VERIFICATION_ENABLED=true

# Only require SMS verification on first login (true/false)
# If false, SMS verification required on every login until manual reset
SMS_VERIFICATION_FIRST_LOGIN_ONLY=true

# n8n Face Quality Gate (image quality checks before Face ID enrollment)
# Example: http://localhost:5678/webhook-test/face-quality
# If empty, quality gate is disabled and images will not be sent to n8n
N8N_FACE_QUALITY_URL=http://localhost:5678/webhook-test/webhook-test/face-quality
# Timeout for the quality gate request in milliseconds (default: 15000)
N8N_FACE_QUALITY_TIMEOUT_MS=15000

# If true, users may bypass a failing quality check and continue enrollment
# Use with caution; recommended for testing only
N8N_FACE_QUALITY_ALLOW_BYPASS=false
