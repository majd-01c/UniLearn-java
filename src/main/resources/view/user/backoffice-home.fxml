<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.BackOfficeHomeController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="admin-scroll">
    <content>
        <VBox fx:id="rootContainer" spacing="18.0" styleClass="admin-home-root">
            <padding>
                <Insets top="24.0" right="24.0" bottom="28.0" left="24.0"/>
            </padding>
            <children>
                <HBox spacing="18.0" alignment="CENTER_LEFT" styleClass="admin-hero">
                    <children>
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="BackOffice" styleClass="admin-title-chip"/>
                                        <Label fx:id="roleLabel" text="ADMIN" styleClass="admin-role-pill"/>
                                    </children>
                                </HBox>
                                <Label fx:id="welcomeLabel" text="Welcome to BackOffice" styleClass="admin-page-title"/>
                                <Label text="Manage users, moderation, academic operations, and service access from one admin workspace."
                                       wrapText="true" styleClass="admin-hero-summary"/>
                                <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="admin-hero-actions">
                                    <children>
                                        <Button text="Open User List"
                                                onAction="#onOpenUsers"
                                                styleClass="admin-primary-button"/>
                                        <Button text="Manage Job Offers"
                                                onAction="#onOpenJobOfferManagement"
                                                styleClass="admin-secondary-button"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" styleClass="admin-hero-side">
                            <children>
                                <Label text="Admin Focus" styleClass="admin-section-eyebrow"/>
                                <Label fx:id="usersCountLabel" text="Total users: -" wrapText="true" styleClass="admin-focus-value"/>
                                <Label fx:id="pendingActionsLabel" text="Pending actions: -" wrapText="true" styleClass="admin-focus-muted"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <TilePane hgap="14.0" vgap="14.0" prefTileWidth="220.0" prefColumns="4"
                          tileAlignment="TOP_LEFT" styleClass="admin-stat-grid">
                    <children>
                        <VBox spacing="8.0" styleClass="admin-stat-card">
                            <children>
                                <Label text="Total Users" styleClass="admin-stat-title"/>
                                <Label fx:id="totalUsersStatLabel" text="-" styleClass="admin-stat-value"/>
                                <Label text="All registered accounts" styleClass="admin-stat-helper"/>
                            </children>
                        </VBox>
                        <VBox spacing="8.0" styleClass="admin-stat-card">
                            <children>
                                <Label text="Active Accounts" styleClass="admin-stat-title"/>
                                <Label fx:id="activeUsersStatLabel" text="-" styleClass="admin-stat-value"/>
                                <Label text="Ready to use the platform" styleClass="admin-stat-helper"/>
                            </children>
                        </VBox>
                        <VBox spacing="8.0" styleClass="admin-stat-card">
                            <children>
                                <Label text="Inactive Accounts" styleClass="admin-stat-title"/>
                                <Label fx:id="inactiveUsersStatLabel" text="-" styleClass="admin-stat-value"/>
                                <Label text="Need review or activation" styleClass="admin-stat-helper"/>
                            </children>
                        </VBox>
                        <VBox spacing="8.0" styleClass="admin-stat-card">
                            <children>
                                <Label text="Recent Users" styleClass="admin-stat-title"/>
                                <Label fx:id="recentUsersStatLabel" text="-" styleClass="admin-stat-value"/>
                                <Label text="Latest account activity" styleClass="admin-stat-helper"/>
                            </children>
                        </VBox>
                    </children>
                </TilePane>

                <TilePane hgap="14.0" vgap="14.0" prefTileWidth="286.0" prefColumns="3"
                          tileAlignment="TOP_LEFT" styleClass="admin-action-grid">
                    <children>
                        <VBox spacing="10.0" styleClass="admin-action-card">
                            <children>
                                <Label text="User Operations" styleClass="admin-action-title"/>
                                <Label text="Open the full account directory and manage user lifecycle changes."
                                       wrapText="true" styleClass="admin-action-text"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button text="Open User List"
                                        onAction="#onOpenUsers"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="admin-primary-button"/>
                                <Button text="My Profile"
                                        onAction="#onOpenProfile"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="admin-secondary-button"/>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" styleClass="admin-action-card">
                            <children>
                                <Label text="Academic Controls" styleClass="admin-action-title"/>
                                <Label text="Jump to evaluations, programs, classes, and academic setup tools."
                                       wrapText="true" styleClass="admin-action-text"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button text="Open Evaluation"
                                        onAction="#onOpenEvaluation"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="admin-primary-button"/>
                                <Button text="Program/Class Shortcut"
                                        onAction="#onOpenProgramManagement"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="admin-secondary-button"/>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" styleClass="admin-action-card">
                            <children>
                                <Label text="Services &amp; Moderation" styleClass="admin-action-title"/>
                                <Label text="Review job offers, forum categories, moderation queues, and service activity."
                                       wrapText="true" styleClass="admin-action-text"/>
                                <Region VBox.vgrow="ALWAYS"/>
                                <Button text="Manage Job Offers"
                                        onAction="#onOpenJobOfferManagement"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="admin-primary-button"/>
                                <Button text="Moderation Shortcut"
                                        onAction="#onOpenModeration"
                                        maxWidth="1.7976931348623157E308"
                                        styleClass="admin-secondary-button"/>
                            </children>
                        </VBox>
                    </children>
                </TilePane>

                <VBox spacing="10.0" styleClass="admin-summary-card">
                    <children>
                        <Label text="Operational Snapshot" styleClass="admin-action-title"/>
                        <Label fx:id="recentActivityLabel" text="Recent activity: -" styleClass="admin-action-text"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
