<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.PasswordResetController"
            prefWidth="700.0" prefHeight="480.0">

    <center>
        <VBox alignment="CENTER" spacing="12.0">
            <padding>
                <Insets top="24.0" right="28.0" bottom="24.0" left="28.0"/>
            </padding>
            <children>
                <Label text="Reset Password" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Paste the token or reset URL, then choose a new password." style="-fx-text-fill: #6b7280;"/>

                <GridPane hgap="10.0" vgap="12.0" maxWidth="640.0">
                    <children>
                        <Label text="Token / URL" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="tokenField" promptText="token or https://.../reset-password?token=..."
                                   GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="440.0"/>
                        <Button text="Validate Token" onAction="#onValidateToken"
                                GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                        <Label text="New Password" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <PasswordField fx:id="newPasswordField" promptText="New password"
                                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Confirm Password" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"
                                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Strength" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <children>
                                <ProgressBar fx:id="passwordStrengthBar" prefWidth="440.0" progress="0.0"/>
                                <Label fx:id="passwordStrengthLabel" text="Strength: -"/>
                            </children>
                        </VBox>
                    </children>
                </GridPane>

                <Button text="Reset Password" onAction="#onResetPassword" prefWidth="180.0"/>
                <Label fx:id="messageLabel" style="-fx-text-fill: #1f8b4c;"/>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Hyperlink text="Back to Login" onAction="#onGoToLogin"/>
                        <Hyperlink text="Request New Token" onAction="#onGoToRequestReset"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

</BorderPane>
