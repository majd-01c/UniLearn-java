<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.UserProfileController"
            styleClass="user-profile-root">
    <center>
        <VBox spacing="14.0" alignment="CENTER" styleClass="user-profile-shell">
            <padding>
                <Insets top="18.0" right="22.0" bottom="18.0" left="22.0"/>
            </padding>
            <children>
                <VBox spacing="4.0" alignment="CENTER_LEFT" styleClass="user-profile-header">
                    <children>
                        <Label text="My Profile" styleClass="home-title"/>
                        <Label text="Manage your account identity and contact details." styleClass="home-summary"/>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="user-profile-card">
                    <children>
                        <GridPane hgap="12.0" vgap="11.0" maxWidth="560.0">
                            <children>
                                <Label text="Role" styleClass="user-profile-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label fx:id="roleLabel" styleClass="user-profile-chip user-profile-role-chip" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label text="Status" styleClass="user-profile-field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label fx:id="statusLabel" styleClass="user-profile-chip" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="Name" styleClass="user-profile-field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <TextField fx:id="nameField" onAction="#handleSaveProfile" styleClass="user-profile-input" prefWidth="360.0" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label text="Email" styleClass="user-profile-field-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                <TextField fx:id="emailField" onAction="#handleSaveProfile" styleClass="user-profile-input" prefWidth="360.0" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                <Label text="Phone" styleClass="user-profile-field-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                <TextField fx:id="phoneField" onAction="#handleSaveProfile" styleClass="user-profile-input" prefWidth="360.0" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                                <Label text="Location" styleClass="user-profile-field-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                                <TextField fx:id="locationField" onAction="#handleSaveProfile" styleClass="user-profile-input" prefWidth="360.0" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                            </children>
                        </GridPane>

                        <HBox spacing="10.0" alignment="CENTER_RIGHT" styleClass="user-profile-actions">
                            <children>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="saveProfileButton" text="Save Profile" onAction="#handleSaveProfile" prefWidth="130.0" styleClass="primary-button"/>
                                <Button fx:id="backToDashboardButton" text="Back to Home" onAction="#handleBackToDashboard" prefWidth="140.0" styleClass="ghost-button"/>
                                <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" prefWidth="110.0" styleClass="danger-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Label fx:id="messageLabel" styleClass="user-profile-message" wrapText="true" maxWidth="620.0"/>
            </children>
        </VBox>
    </center>
</BorderPane>
