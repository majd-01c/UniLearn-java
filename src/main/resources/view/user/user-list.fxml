<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.UserListController"
            styleClass="user-list-root">
    <top>
        <VBox spacing="10.0" styleClass="user-list-toolbar">
            <padding>
                <Insets top="14.0" right="14.0" bottom="10.0" left="14.0"/>
            </padding>
            <children>
                <Label text="User Management" styleClass="card-title"/>
                <HBox spacing="8.0">
                    <children>
                        <TextField fx:id="searchField" promptText="Search by email, first name, last name" prefWidth="320.0"/>
                        <ComboBox fx:id="roleFilterComboBox" prefWidth="150.0"/>
                        <ComboBox fx:id="statusFilterComboBox" prefWidth="130.0"/>
                        <Button text="Refresh" onAction="#onRefreshUsers" styleClass="ghost-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <StackPane styleClass="user-list-center-surface">
            <children>
                <ScrollPane fx:id="usersScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="user-cards-scroll">
                    <content>
                        <FlowPane fx:id="userCardsContainer" hgap="14.0" vgap="14.0" prefWrapLength="920.0" styleClass="user-cards-grid">
                            <padding>
                                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0"/>
                            </padding>
                        </FlowPane>
                    </content>
                </ScrollPane>

                <Label fx:id="emptyStateLabel"
                       text="No users found for the selected filters."
                       styleClass="user-list-empty-state"
                       visible="false"
                       managed="false"/>
            </children>
        </StackPane>
    </center>

    <bottom>
        <VBox spacing="10.0" styleClass="user-list-actions">
            <padding>
                <Insets top="10.0" right="14.0" bottom="14.0" left="14.0"/>
            </padding>
            <children>
                <Pagination fx:id="pagination"/>
                <HBox spacing="8.0">
                    <children>
                        <Button text="Create User" onAction="#onCreateUser" prefWidth="130.0" styleClass="primary-button"/>
                        <Button text="Edit" onAction="#onEditUser" prefWidth="110.0" styleClass="ghost-button"/>
                        <Button text="Delete" onAction="#onDeleteUser" prefWidth="110.0" styleClass="ghost-button"/>
                        <Button text="Toggle Status" onAction="#onToggleStatus" prefWidth="130.0" styleClass="ghost-button"/>
                        <Button text="Change My Password" onAction="#onChangeMyPassword" prefWidth="170.0" styleClass="ghost-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </bottom>
</BorderPane>
