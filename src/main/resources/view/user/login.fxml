<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.LoginController">
    <center>
        <VBox alignment="CENTER" spacing="14.0">
            <padding>
                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
            </padding>
            <children>
                <Label text="UniLearn Desktop - Login" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Only admins can create accounts." style="-fx-text-fill: #666666;"/>
                <GridPane hgap="10.0" vgap="12.0" maxWidth="420.0">
                    <children>
                        <Label text="Email" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="emailField" promptText="name@unilearn.tn" onAction="#handleLogin"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Password" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <PasswordField fx:id="passwordField" promptText="Password" onAction="#handleLogin"
                                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </children>
                </GridPane>
                <Button fx:id="loginButton" text="Login" onAction="#handleLogin" prefWidth="160.0"/>
                <Label fx:id="messageLabel" style="-fx-text-fill: #c0392b;"/>
            </children>
        </VBox>
    </center>
</BorderPane>
