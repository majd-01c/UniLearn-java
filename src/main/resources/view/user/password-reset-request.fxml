<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.PasswordResetRequestController"
            prefWidth="680.0" prefHeight="430.0">

    <center>
        <VBox alignment="CENTER" spacing="14.0">
            <padding>
                <Insets top="26.0" right="28.0" bottom="26.0" left="28.0"/>
            </padding>
            <children>
                <Label text="Request Password Reset" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Enter your account email and we will send a reset token/link." style="-fx-text-fill: #6b7280;"/>

                <HBox alignment="CENTER" spacing="10.0" maxWidth="520.0">
                    <children>
                        <Label text="Email"/>
                        <TextField fx:id="emailField" promptText="name@unilearn.tn" prefWidth="360.0"/>
                    </children>
                </HBox>

                <Button text="Send Reset Link" onAction="#onSendResetLink" prefWidth="180.0"/>
                <Label fx:id="messageLabel" style="-fx-text-fill: #1f8b4c;"/>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Hyperlink text="Back to Login" onAction="#onGoToLogin"/>
                        <Hyperlink text="I have a token" onAction="#onOpenResetPassword"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

</BorderPane>
