<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.forum.ForumHomeController"
            fitToWidth="true" styleClass="forum-scroll-pane">
    <VBox spacing="16.0" styleClass="forum-root">
        <padding>
            <Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/>
        </padding>

        <!-- Header -->
        <HBox spacing="12.0" alignment="CENTER_LEFT">
            <VBox>
                <Label text="💬 Community Forum" styleClass="forum-page-title"/>
                <Label text="Ask questions, share knowledge, and connect with others" styleClass="forum-page-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="newTopicButton" text="+ New Topic" onAction="#onNewTopic" styleClass="primary-button"/>
        </HBox>

        <HBox spacing="16.0">
            <!-- Main Content (Left) -->
            <VBox spacing="16.0" HBox.hgrow="ALWAYS">
                <!-- Categories Card -->
                <VBox styleClass="forum-card">
                    <Label text="📂 Categories" styleClass="forum-card-title"/>
                    <VBox fx:id="categoriesContainer" spacing="2.0"/>
                </VBox>

                <!-- Recent Topics Card -->
                <VBox styleClass="forum-card">
                    <Label text="🕐 Recent Discussions" styleClass="forum-card-title"/>
                    <VBox fx:id="recentTopicsContainer" spacing="2.0"/>
                </VBox>
            </VBox>

            <!-- Sidebar (Right) -->
            <VBox spacing="16.0" prefWidth="280.0" minWidth="250.0">
                <!-- Stats Card -->
                <VBox styleClass="forum-card">
                    <Label text="📊 Forum Stats" styleClass="forum-card-title"/>
                    <HBox spacing="16.0" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="2.0">
                            <Label fx:id="statCategoriesLabel" text="0" styleClass="forum-stat-number"/>
                            <Label text="Categories" styleClass="forum-stat-label"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="2.0">
                            <Label fx:id="statTopicsLabel" text="0" styleClass="forum-stat-number"/>
                            <Label text="Topics" styleClass="forum-stat-label"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="2.0">
                            <Label fx:id="statUnansweredLabel" text="0" styleClass="forum-stat-number"/>
                            <Label text="Unanswered" styleClass="forum-stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Unanswered Card -->
                <VBox styleClass="forum-card">
                    <Label text="❓ Needs Answer" styleClass="forum-card-title"/>
                    <VBox fx:id="unansweredContainer" spacing="2.0"/>
                </VBox>

                <!-- Admin Tools -->
                <VBox fx:id="adminToolsBox" styleClass="forum-card" managed="false" visible="false">
                    <Label text="⚙ Admin Tools" styleClass="forum-card-title"/>
                    <Button text="Manage Categories" onAction="#onManageCategories"
                            maxWidth="1.7976931348623157E308" styleClass="ghost-button"/>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
