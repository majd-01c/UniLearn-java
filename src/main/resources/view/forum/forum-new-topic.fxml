<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.forum.ForumNewTopicController"
      spacing="16.0" styleClass="forum-root">
    <padding>
        <Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/>
    </padding>

    <Label text="📝 Create New Topic" styleClass="forum-page-title"/>

    <VBox spacing="12.0" styleClass="forum-card" maxWidth="700.0">
        <!-- Category -->
        <VBox spacing="4.0">
            <Label text="Category" styleClass="forum-form-label"/>
            <ComboBox fx:id="categoryComboBox" maxWidth="1.7976931348623157E308" promptText="Select a category..." styleClass="forum-combo-box"/>
            <Label fx:id="categoryErrorLabel" text="" styleClass="forum-error-label"/>
        </VBox>

        <!-- Title -->
        <VBox spacing="4.0">
            <Label text="Title" styleClass="forum-form-label"/>
            <TextField fx:id="titleField" promptText="Enter topic title (min 5 characters)..." styleClass="forum-text-field"/>
            <Label fx:id="titleErrorLabel" text="" styleClass="forum-error-label"/>
        </VBox>

        <!-- Content -->
        <VBox spacing="4.0">
            <Label text="Content" styleClass="forum-form-label"/>
            <TextArea fx:id="contentArea" promptText="Describe your topic in detail..." prefRowCount="8" styleClass="forum-text-area"/>
            <Label fx:id="contentErrorLabel" text="" styleClass="forum-error-label"/>
        </VBox>

        <!-- AI Suggestions -->
        <VBox fx:id="aiSuggestionsBox" spacing="10.0" styleClass="forum-ai-card" visible="false" managed="false">
            <HBox spacing="8.0" alignment="CENTER_LEFT">
                <Label text="AI Assistant" styleClass="forum-ai-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ProgressIndicator fx:id="aiLoadingIndicator" prefWidth="18.0" prefHeight="18.0" visible="false" managed="false"/>
                <Label fx:id="aiStatusLabel" text="" styleClass="forum-ai-muted"/>
            </HBox>
            <VBox fx:id="aiResultsBox" spacing="8.0"/>
            <Label text="AI-generated results may not always be accurate." styleClass="forum-ai-muted" wrapText="true"/>
        </VBox>

        <!-- Actions -->
        <HBox spacing="12.0">
            <Button text="Create Topic" onAction="#onSaveTopic" styleClass="primary-button"/>
            <Button text="Cancel" onAction="#onCancel" styleClass="ghost-button"/>
        </HBox>
    </VBox>
</VBox>
