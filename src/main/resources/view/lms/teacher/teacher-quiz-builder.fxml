<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.lms.TeacherQuizBuilderController"
            styleClass="app-shell-root">
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="lms-root quiz-builder-hero" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18" right="24" bottom="16" left="24"/>
            </padding>
            <VBox spacing="4">
                <Label text="Quiz Builder" styleClass="lms-page-title"/>
                <Label fx:id="courseContextLabel" text="Course: " styleClass="lms-text"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox spacing="2" styleClass="quiz-stat-card" alignment="CENTER_LEFT">
                <Label fx:id="questionCountLabel" text="0" styleClass="quiz-stat-value"/>
                <Label text="Questions" styleClass="stat-label"/>
            </VBox>
            <VBox spacing="2" styleClass="quiz-stat-card" alignment="CENTER_LEFT">
                <Label fx:id="totalPointsLabel" text="0" styleClass="quiz-stat-value"/>
                <Label text="Points" styleClass="stat-label"/>
            </VBox>
            <Button text="Cancel" onAction="#onCancel" styleClass="ghost-button"/>
            <Button text="Save Quiz" onAction="#onSaveQuiz" styleClass="primary-button"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="lms-scroll" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20" right="24" bottom="24" left="24"/>
            </padding>
            <VBox spacing="20" maxWidth="1120">
                <HBox spacing="20" alignment="TOP_LEFT">
                    <VBox spacing="16" styleClass="lms-card quiz-builder-settings" HBox.hgrow="ALWAYS">
                        <Label text="Quiz Setup" styleClass="card-title"/>
                        <Label text="Set the core details students see before starting." styleClass="card-text" wrapText="true"/>

                        <VBox spacing="8">
                            <Label text="Quiz Title *" styleClass="form-label"/>
                            <TextField fx:id="quizTitleField" promptText="Example: Java basics checkpoint" styleClass="lms-input"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Description" styleClass="form-label"/>
                            <TextArea fx:id="quizDescriptionField" promptText="Add instructions, covered chapters, or rules." prefRowCount="4" styleClass="lms-input" wrapText="true"/>
                        </VBox>
                    </VBox>

                    <VBox spacing="16" styleClass="lms-card quiz-builder-rules" prefWidth="300">
                        <Label text="Rules" styleClass="card-title"/>
                        <VBox spacing="8">
                            <Label text="Time Limit (minutes) *" styleClass="form-label"/>
                            <Spinner fx:id="timeLimitSpinner" editable="true" maxWidth="1.7976931348623157E308" styleClass="lms-input"/>
                        </VBox>
                        <VBox spacing="8">
                            <Label text="Passing Score (%) *" styleClass="form-label"/>
                            <Spinner fx:id="passingScoreSpinner" editable="true" maxWidth="1.7976931348623157E308" styleClass="lms-input"/>
                        </VBox>
                        <Label fx:id="builderStatusLabel" text="Draft not saved yet" styleClass="quiz-save-status" wrapText="true"/>
                    </VBox>
                </HBox>

                <Label fx:id="errorLabel" styleClass="field-error quiz-error-banner" visible="false" managed="false" wrapText="true"/>

                <VBox spacing="16">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <VBox spacing="3">
                            <Label text="Questions" styleClass="lms-page-title"/>
                            <Label text="Add clear questions, choose points, and mark the correct answer for multiple choice items." styleClass="lms-text" wrapText="true"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Add Question" onAction="#onAddQuestion" styleClass="primary-button"/>
                    </HBox>

                    <VBox fx:id="questionsContainer" spacing="16"/>

                    <VBox fx:id="emptyQuestionState" alignment="CENTER" spacing="12" styleClass="lms-card quiz-empty-builder">
                        <Label text="No questions added yet." styleClass="card-title" fx:id="noQuestionsLabel"/>
                        <Label text="Start with one multiple choice or text question. You can edit or remove it before saving." styleClass="card-text" wrapText="true"/>
                        <Button text="Add Your First Question" onAction="#onAddQuestion" styleClass="primary-button"/>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
