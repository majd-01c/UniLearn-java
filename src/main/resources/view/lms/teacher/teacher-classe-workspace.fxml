<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?><?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.lms.TeacherClasseWorkspaceController" styleClass="lms-scroll" fitToWidth="true">
<VBox styleClass="lms-root" spacing="16"><padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
    <HBox styleClass="breadcrumb-bar"><Button text="My Classes" onAction="#onBack" styleClass="breadcrumb-link"/><Label text=" › " styleClass="breadcrumb-sep"/><Label fx:id="breadcrumb" text="Workspace" styleClass="breadcrumb-current"/></HBox>
    <!-- Module Creation (before module exists) -->
    <VBox fx:id="createModulePane" styleClass="lms-card" spacing="12" visible="false" managed="false">
        <Label text="Create Your Module" styleClass="card-title"/>
        <VBox spacing="4" styleClass="lms-form"><Label text="Module Name" styleClass="form-label"/><TextField fx:id="moduleNameField" styleClass="lms-input"/></VBox>
        <HBox spacing="12"><VBox spacing="4" styleClass="lms-form" HBox.hgrow="ALWAYS"><Label text="Period Unit" styleClass="form-label"/><ComboBox fx:id="modulePeriodField" maxWidth="1.7976931348623157E308"/></VBox>
        <VBox spacing="4" styleClass="lms-form" HBox.hgrow="ALWAYS"><Label text="Duration" styleClass="form-label"/><Spinner fx:id="moduleDurationField" min="1" max="999" initialValue="1"/></VBox></HBox>
        <Label fx:id="createErrorLabel" styleClass="field-error" visible="false" managed="false" wrapText="true"/>
        <Button text="Create Module" onAction="#onCreateModule" styleClass="primary-button"/>
    </VBox>
    <!-- Workspace (after module exists) -->
    <VBox fx:id="workspacePane" spacing="16" visible="false" managed="false">
        <VBox styleClass="lms-card" spacing="8"><Label fx:id="moduleInfoLabel" styleClass="card-title"/><Label fx:id="moduleDurationLabel" styleClass="card-text"/></VBox>
        <!-- Courses & Content management -->
        <VBox styleClass="lms-card" spacing="12">
            <HBox spacing="12" alignment="CENTER_LEFT"><Label text="Courses" styleClass="card-title"/><Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="courseSelector" promptText="Select course..." prefWidth="240"/>
                <Button text="+ Add Course" onAction="#onAddCourse" styleClass="primary-button"/></HBox>
            <VBox fx:id="coursesContainer" spacing="12"/>
        </VBox>
    </VBox>
</VBox>
</ScrollPane>
