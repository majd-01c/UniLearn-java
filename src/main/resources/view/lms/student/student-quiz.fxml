<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.lms.StudentQuizController"
            styleClass="app-shell-root">
    <top>
        <VBox spacing="12" styleClass="lms-root quiz-hero" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="18" right="24" bottom="16" left="24"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4">
                    <Label text="Quizzes" styleClass="lms-page-title"/>
                    <Label text="Start new quizzes, continue saved answers, and review past results." styleClass="lms-text" wrapText="true"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <VBox spacing="2" styleClass="quiz-stat-card" alignment="CENTER_LEFT">
                        <Label fx:id="totalQuizzesLabel" text="0" styleClass="quiz-stat-value"/>
                        <Label text="Available" styleClass="stat-label"/>
                    </VBox>
                    <VBox spacing="2" styleClass="quiz-stat-card" alignment="CENTER_LEFT">
                        <Label fx:id="pendingQuizzesLabel" text="0" styleClass="quiz-stat-value"/>
                        <Label text="To Do" styleClass="stat-label"/>
                    </VBox>
                    <VBox spacing="2" styleClass="quiz-stat-card" alignment="CENTER_LEFT">
                        <Label fx:id="completedQuizzesLabel" text="0" styleClass="quiz-stat-value"/>
                        <Label text="Completed" styleClass="stat-label"/>
                    </VBox>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="screenStack" styleClass="lms-root">
            <VBox fx:id="quizListScreen" spacing="16" maxWidth="1180" StackPane.alignment="TOP_CENTER">
                <padding>
                    <Insets top="20" right="24" bottom="24" left="24"/>
                </padding>
                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="lms-card quiz-section-header">
                    <VBox spacing="4">
                        <Label text="Available Quizzes" styleClass="card-title"/>
                        <Label text="Pick a quiz card to begin. Completed quizzes open in review mode." styleClass="card-text" wrapText="true"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Auto-save is enabled while answering" styleClass="quiz-save-status"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="lms-scroll" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="quizListFlow" hgap="18" vgap="18" style="-fx-padding: 4;"/>
                </ScrollPane>

                <VBox fx:id="emptyQuizzesBox" alignment="CENTER" spacing="10" styleClass="lms-card quiz-empty-state" visible="false" managed="false">
                    <Label fx:id="emptyQuizzesLabel"
                           text="No quizzes are available for your classes yet."
                           styleClass="empty-state"
                           visible="false"
                           managed="false"/>
                </VBox>
            </VBox>

            <VBox fx:id="quizTakingScreen" spacing="14" visible="false" managed="false" maxWidth="1180" StackPane.alignment="TOP_CENTER">
                <padding>
                    <Insets top="20" right="24" bottom="24" left="24"/>
                </padding>

                <VBox spacing="12" styleClass="lms-card quiz-taking-header">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label fx:id="quizTitleLabel" styleClass="card-title"/>
                            <Label fx:id="quizDescriptionLabel" text="Quiz description" styleClass="card-text" wrapText="true"/>
                        </VBox>
                        <Label fx:id="timerLabel" text="30:00" styleClass="quiz-timer"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label fx:id="progressLabel" text="Question 1 of 10" styleClass="quiz-progress"/>
                                <Label fx:id="saveStatusLabel" text="Ready" styleClass="quiz-save-status"/>
                            </HBox>
                            <ProgressBar fx:id="quizProgressBar" progress="0" maxWidth="1.7976931348623157E308" styleClass="quiz-progress-bar"/>
                        </VBox>
                    </HBox>
                    <FlowPane fx:id="questionNavigator" hgap="8" vgap="8"/>
                </VBox>

                <ScrollPane fx:id="questionsScrollPane" fitToWidth="true" styleClass="lms-scroll" VBox.vgrow="ALWAYS">
                    <VBox fx:id="questionsContainer" spacing="16" style="-fx-padding: 4;"/>
                </ScrollPane>

                <HBox fx:id="navigationBox" spacing="12" alignment="CENTER_LEFT" styleClass="lms-card quiz-action-bar">
                    <Button fx:id="previousButton" text="Previous" styleClass="ghost-button"/>
                    <Button fx:id="nextButton" text="Next" styleClass="ghost-button"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="submitButton" text="Submit Quiz" styleClass="primary-button"/>
                </HBox>
            </VBox>

            <ScrollPane fx:id="resultsScreen" fitToWidth="true" visible="false" managed="false" maxWidth="1180" StackPane.alignment="TOP_CENTER" styleClass="lms-scroll">
                <VBox spacing="16" style="-fx-padding: 20 24 24 24;">
                    <VBox spacing="8" styleClass="lms-card quiz-results-hero">
                        <Label fx:id="resultsTitleLabel" styleClass="card-title"/>
                        <Label fx:id="resultsDescriptionLabel" styleClass="card-text" wrapText="true"/>
                    </VBox>

                    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="lms-card quiz-score-card">
                        <VBox spacing="6" alignment="CENTER_LEFT">
                            <Label fx:id="scoreLabel" text="0/0 (0%)" styleClass="quiz-score-value"/>
                            <Label text="Your Score" styleClass="card-text"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="passStatusLabel" text="PASSED" styleClass="quiz-score-passed"/>
                    </HBox>

                    <Label text="Question Review" styleClass="card-title"/>
                    <VBox fx:id="questionReviewBox" spacing="12"/>

                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="lms-card">
                        <Button fx:id="backToListButton" text="Back to Quizzes" styleClass="primary-button"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </StackPane>
    </center>
</BorderPane>
