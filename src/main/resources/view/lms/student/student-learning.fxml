<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.lms.StudentLearningController"
            styleClass="lms-scroll" fitToWidth="true">
    <VBox styleClass="lms-root" spacing="16">
        <padding>
            <Insets top="12" right="16" bottom="16" left="16"/>
        </padding>

        <!-- Page Header -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="My Learning" styleClass="lms-page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="quizzesButton" text="📝  Take a Quiz" onAction="#onGoToQuizzes"
                    styleClass="primary-button"/>
        </HBox>

        <!-- Stats Summary -->
        <HBox fx:id="statsBox" spacing="12">
            <VBox styleClass="stat-card" spacing="4" alignment="CENTER">
                <Label fx:id="classCountLabel" text="0" styleClass="stat-value"/>
                <Label text="Enrolled Classes" styleClass="stat-label"/>
            </VBox>
        </HBox>

        <!-- Class Cards -->
        <FlowPane fx:id="classesPane" hgap="16" vgap="16"/>

        <!-- Empty State -->
        <Label fx:id="emptyLabel" text="You are not enrolled in any classes yet."
               styleClass="empty-state" visible="false" managed="false"/>
    </VBox>
</ScrollPane>
