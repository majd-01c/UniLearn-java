<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?><?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.lms.AdminClasseFormController" styleClass="lms-root" spacing="16" maxWidth="650">
    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
    <HBox styleClass="breadcrumb-bar"><Button text="Classes" onAction="#onBack" styleClass="breadcrumb-link"/><Label text=" › " styleClass="breadcrumb-sep"/><Label fx:id="breadcrumb" text="New Class" styleClass="breadcrumb-current"/></HBox>
    <VBox styleClass="lms-card" spacing="12">
        <Label fx:id="formTitle" text="Create New Class" styleClass="card-title"/>
        <VBox spacing="4" styleClass="lms-form"><Label text="Name" styleClass="form-label"/><TextField fx:id="nameField" styleClass="lms-input"/></VBox>
        <VBox spacing="4" styleClass="lms-form"><Label text="Program" styleClass="form-label"/><ComboBox fx:id="programField" maxWidth="1.7976931348623157E308"/></VBox>
        <HBox spacing="12"><VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="lms-form"><Label text="Level" styleClass="form-label"/><ComboBox fx:id="levelField" promptText="-- Select level --" maxWidth="1.7976931348623157E308"/></VBox><VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="lms-form"><Label text="Specialty" styleClass="form-label"/><ComboBox fx:id="specialtyField" promptText="-- Select specialty --" maxWidth="1.7976931348623157E308"/></VBox></HBox>
        <VBox spacing="4" styleClass="lms-form"><Label text="Capacity" styleClass="form-label"/><Spinner fx:id="capacityField" min="1" max="500" initialValue="30"/></VBox>
        <HBox spacing="12"><VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="lms-form"><Label text="Start Date" styleClass="form-label"/><DatePicker fx:id="startDateField"/></VBox><VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="lms-form"><Label text="End Date" styleClass="form-label"/><DatePicker fx:id="endDateField"/></VBox></HBox>
        <Label fx:id="errorLabel" styleClass="field-error" visible="false" managed="false" wrapText="true"/>
        <HBox spacing="12" alignment="CENTER_RIGHT"><Button text="Cancel" onAction="#onBack" styleClass="ghost-button"/><Button text="Save" onAction="#onSave" styleClass="primary-button"/></HBox>
    </VBox>
</VBox>
