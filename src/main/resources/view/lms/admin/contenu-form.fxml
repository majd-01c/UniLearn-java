<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.HTMLEditor?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.lms.AdminContenuFormController" styleClass="lms-root" spacing="16" maxWidth="760">
    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>

    <HBox styleClass="breadcrumb-bar" spacing="6">
        <Button text="Content" onAction="#onBack" styleClass="breadcrumb-link"/>
        <Label text="›" styleClass="breadcrumb-sep"/>
        <Label fx:id="breadcrumb" text="New Content" styleClass="breadcrumb-current"/>
    </HBox>

    <VBox styleClass="lms-card" spacing="12">
        <Label fx:id="formTitle" text="Create New Content" styleClass="card-title"/>

        <VBox spacing="4" styleClass="lms-form">
            <Label text="Title" styleClass="form-label"/>
            <TextField fx:id="titleField" styleClass="lms-input"/>
        </VBox>

        <VBox spacing="4" styleClass="lms-form">
            <Label text="Type" styleClass="form-label"/>
            <ComboBox fx:id="typeField" maxWidth="1.7976931348623157E308"/>
        </VBox>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <CheckBox fx:id="publishedCheck" text="Published"/>
        </HBox>

        <VBox spacing="6" styleClass="lms-form">
            <Label text="Content Source" styleClass="form-label"/>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <RadioButton fx:id="editorRadio" text="Write in app" toggleGroup="$sourceToggle" onAction="#onSourceChanged"/>
                <RadioButton fx:id="uploadRadio" text="Upload file" toggleGroup="$sourceToggle" onAction="#onSourceChanged"/>
            </HBox>
        </VBox>

        <VBox fx:id="editorSection" spacing="6" styleClass="lms-form">
            <Label text="Write your content" styleClass="form-label"/>
            <HTMLEditor fx:id="contentEditor" prefHeight="320.0"/>
        </VBox>

        <VBox fx:id="fileSection" spacing="6" styleClass="lms-form">
            <Label text="File" styleClass="form-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="fileLabel" text="No file selected" styleClass="card-text"/>
                <Button fx:id="chooseFileButton" text="Choose File" onAction="#onChooseFile" styleClass="ghost-button"/>
            </HBox>
        </VBox>

        <Label fx:id="errorLabel" styleClass="field-error" visible="false" managed="false" wrapText="true"/>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Cancel" onAction="#onBack" styleClass="ghost-button"/>
            <Button text="Save" onAction="#onSave" styleClass="primary-button"/>
        </HBox>
    </VBox>

    <fx:define>
        <ToggleGroup fx:id="sourceToggle"/>
    </fx:define>
</VBox>
