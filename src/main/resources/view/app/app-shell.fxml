<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.AppShellController"
            styleClass="app-shell-root">

    <left>
        <VBox fx:id="sideRail" styleClass="app-side-rail" prefWidth="228.0" spacing="8.0">
            <padding>
                <Insets top="16.0" right="12.0" bottom="16.0" left="12.0"/>
            </padding>
            <children>
                <Label text="UniLearn" styleClass="brand-title"/>
                <Label text="Desktop Workspace" styleClass="brand-subtitle"/>
                <Region prefHeight="10.0"/>

                <Button fx:id="navHomeButton" text="Home" onAction="#onNavHome" maxWidth="1.7976931348623157E308" styleClass="side-button"/>
                <Button fx:id="navUsersButton" text="Users" onAction="#onNavUsers" maxWidth="1.7976931348623157E308" styleClass="side-button"/>
                <Button fx:id="navProfileButton" text="My Profile" onAction="#onNavProfile" maxWidth="1.7976931348623157E308" styleClass="side-button"/>
                <Button fx:id="navChangePasswordButton" text="Change Password" onAction="#onNavChangePassword" maxWidth="1.7976931348623157E308" styleClass="side-button"/>

                <Region VBox.vgrow="ALWAYS"/>
                <Button text="Logout" onAction="#onNavLogout" maxWidth="1.7976931348623157E308" styleClass="side-button side-danger-button"/>
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="app-header">
            <padding>
                <Insets top="14.0" right="18.0" bottom="14.0" left="18.0"/>
            </padding>
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label fx:id="headerTitleLabel" text="UniLearn Desktop" styleClass="header-title"/>
                        <Label fx:id="headerSubtitleLabel" text="Sign in to continue" styleClass="header-subtitle"/>
                        <Label fx:id="breadcrumbsLabel" text="Login" styleClass="header-breadcrumbs"/>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER_RIGHT" spacing="8.0">
                    <children>
                        <Button fx:id="themeToggleButton" text="Dark Theme" onAction="#onToggleTheme" styleClass="theme-toggle-button"/>
                        <StackPane fx:id="currentUserAvatarContainer" styleClass="avatar-container">
                            <children>
                                <ImageView fx:id="currentUserAvatarImageView" fitHeight="30.0" fitWidth="30.0" preserveRatio="false" smooth="true" styleClass="avatar-image"/>
                                <Label fx:id="currentUserInitialsLabel" styleClass="avatar-initials"/>
                            </children>
                        </StackPane>
                        <Label fx:id="currentUserLabel" styleClass="user-badge"/>
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentHost" styleClass="app-content-host" BorderPane.alignment="CENTER"/>
    </center>

</BorderPane>
