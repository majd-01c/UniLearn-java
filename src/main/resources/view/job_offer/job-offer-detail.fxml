<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>
<ScrollPane fx:id="rootContainer"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.job_offer.JobOfferDetailController"
            fitToWidth="true"
            styleClass="job-offer-scroll">
    <content>
        <VBox spacing="18" styleClass="job-offer-root job-offer-detail-page">
            <Button fx:id="backButton"
                    text="Back to Job Offers"
                    styleClass="ghost-button job-offer-back-button"
                    onAction="#onBack"/>

            <VBox spacing="18" styleClass="job-offer-surface-card job-offer-detail-shell">
                <HBox spacing="18" styleClass="job-offer-detail-hero">
                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                        <Label fx:id="titleLabel" styleClass="job-offer-detail-hero-title" wrapText="true"/>
                        <Label text="Review the opportunity details and apply directly from the same page."
                               styleClass="job-offer-detail-hero-subtitle"
                               wrapText="true"/>
                    </VBox>
                    <VBox spacing="10" alignment="TOP_RIGHT">
                        <Label fx:id="typeLabel" styleClass="job-offer-chip job-offer-detail-chip"/>
                        <Label fx:id="statusLabel" styleClass="job-offer-status-chip job-offer-detail-chip"/>
                    </VBox>
                </HBox>

                <HBox spacing="16" alignment="TOP_LEFT" styleClass="job-offer-detail-map-row">
                    <VBox spacing="10" styleClass="job-offer-detail-map-card job-offer-detail-map-card-half">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Job Location on Map" styleClass="job-offer-section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="mapStatusLabel" text="Map ready" styleClass="job-offer-card-meta"/>
                        </HBox>
                        <Label fx:id="locationLabel" styleClass="job-offer-card-meta" wrapText="true"/>
                        <StackPane styleClass="job-offer-map-container job-offer-detail-map-container">
                            <WebView fx:id="locationMapView" prefWidth="420.0" prefHeight="420.0" minWidth="320.0" minHeight="320.0"/>
                            <Label fx:id="mapUnavailableLabel"
                                   text="No job location available for this offer."
                                   styleClass="job-offer-empty-label"
                                   visible="false"
                                   managed="false"/>
                        </StackPane>
                    </VBox>

                    <VBox spacing="14" styleClass="job-offer-detail-summary-side">
                        <VBox spacing="6" styleClass="job-offer-detail-summary-card">
                            <Label text="Posted by" styleClass="job-offer-detail-summary-label"/>
                            <Label fx:id="postedByLabel" styleClass="job-offer-detail-summary-value" wrapText="true"/>
                        </VBox>
                        <VBox spacing="6" styleClass="job-offer-detail-summary-card">
                            <Label text="Minimum Education" styleClass="job-offer-detail-summary-label"/>
                            <Label fx:id="educationLabel" styleClass="job-offer-detail-summary-value" wrapText="true"/>
                        </VBox>
                        <VBox spacing="6" styleClass="job-offer-detail-summary-card">
                            <Label text="Experience Required" styleClass="job-offer-detail-summary-label"/>
                            <Label fx:id="experienceLabel" styleClass="job-offer-detail-summary-value" wrapText="true"/>
                        </VBox>
                    </VBox>
                </HBox>

                <HBox spacing="14" alignment="TOP_LEFT">
                    <VBox spacing="10" styleClass="job-offer-detail-content-card" HBox.hgrow="ALWAYS">
                        <Label text="Description" styleClass="job-offer-section-title"/>
                        <Label fx:id="descriptionLabel" styleClass="job-offer-body-text job-offer-detail-long-text" wrapText="true"/>
                    </VBox>
                    <VBox spacing="10" styleClass="job-offer-detail-content-card" HBox.hgrow="ALWAYS">
                        <Label text="Requirements" styleClass="job-offer-section-title"/>
                        <Label fx:id="requirementsLabel" styleClass="job-offer-body-text job-offer-detail-long-text" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="14" alignment="TOP_LEFT">
                    <VBox spacing="10" styleClass="job-offer-detail-tags-card" HBox.hgrow="ALWAYS">
                        <Label text="Required Skills" styleClass="job-offer-section-title"/>
                        <FlowPane fx:id="requiredSkillsPane" hgap="8" vgap="8"/>
                    </VBox>
                    <VBox spacing="10" styleClass="job-offer-detail-tags-card" HBox.hgrow="ALWAYS">
                        <Label text="Preferred Skills" styleClass="job-offer-section-title"/>
                        <FlowPane fx:id="preferredSkillsPane" hgap="8" vgap="8"/>
                    </VBox>
                    <VBox spacing="10" styleClass="job-offer-detail-tags-card" HBox.hgrow="ALWAYS">
                        <Label text="Languages" styleClass="job-offer-section-title"/>
                        <FlowPane fx:id="languagesPane" hgap="8" vgap="8"/>
                    </VBox>
                </HBox>

                <HBox spacing="24" styleClass="job-offer-detail-meta-row">
                    <Label fx:id="createdAtLabel" styleClass="job-offer-card-meta" wrapText="true"/>
                    <Label fx:id="publishedAtLabel" styleClass="job-offer-card-meta" wrapText="true"/>
                    <Label fx:id="expiresAtLabel" styleClass="job-offer-card-meta" wrapText="true"/>
                </HBox>
            </VBox>

            <VBox fx:id="applicationSection" spacing="16" styleClass="job-offer-surface-card job-offer-detail-application-card">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Apply for this Position" styleClass="job-offer-detail-application-title"/>
                        <Label fx:id="applicationStatusLabel"
                               text="Tell the employer why this opportunity matches your profile."
                               styleClass="job-offer-page-subtitle"
                               wrapText="true"/>
                    </VBox>
                </HBox>

                <VBox spacing="8">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Cover Letter / Message" styleClass="job-offer-section-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="generateMotivationButton"
                                text="Generate with AI"
                                styleClass="ghost-button"
                                onAction="#onGenerateMotivationLetter"/>
                    </HBox>
                    <TextArea fx:id="motivationLetterArea"
                              promptText="Tell the employer why you are interested in this position..."
                              wrapText="true"
                              prefRowCount="8"
                              styleClass="job-offer-text-area job-offer-detail-application-textarea"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Upload CV / Resume" styleClass="job-offer-section-label"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="browseCvButton" text="Choose File" styleClass="ghost-button" onAction="#onBrowseCv"/>
                        <TextField fx:id="cvPathField"
                                   editable="false"
                                   promptText="No file chosen"
                                   HBox.hgrow="ALWAYS"
                                   styleClass="job-offer-input"/>
                    </HBox>
                    <Label text="Allowed formats: PDF, DOC, DOCX" styleClass="job-offer-form-note"/>
                </VBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="applyButton"
                            text="Apply for this Position"
                            styleClass="primary-button job-offer-submit-button"
                            onAction="#onApply"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="editButton" text="Edit" styleClass="ghost-button" onAction="#onEdit"/>
                    <Button fx:id="deleteButton" text="Delete" styleClass="ghost-button job-offer-danger-button" onAction="#onDelete"/>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
