<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.job_offer.JobOfferDetailController" fitToWidth="true">
    <VBox spacing="15" style="-fx-padding: 20;">
        <!-- Header Section -->
        <HBox spacing="15" style="-fx-padding: 15; -fx-background-color: #f5f5f5; -fx-border-radius: 5;">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label fx:id="titleLabel" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                <HBox spacing="10">
                    <Label fx:id="typeLabel" style="-fx-padding: 4 12; -fx-background-color: #e0e0e0; -fx-border-radius: 3;"/>
                    <Label fx:id="statusLabel" style="-fx-padding: 4 12; -fx-background-color: #ff9800; -fx-text-fill: white; -fx-border-radius: 3;"/>
                </HBox>
            </VBox>
            <VBox spacing="10">
                <Button fx:id="editButton" text="Edit" style="-fx-padding: 8 16;"/>
                <Button fx:id="deleteButton" text="Delete" style="-fx-padding: 8 16; -fx-text-fill: #f44336;"/>
            </VBox>
        </HBox>

        <!-- Basic Info -->
        <HBox spacing="30">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #666;">Location</Label>
                <Label fx:id="locationLabel" style="-fx-text-fill: #333;"/>
            </VBox>
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #666;">Posted by</Label>
                <Label fx:id="postedByLabel" style="-fx-text-fill: #333;"/>
            </VBox>
        </HBox>

        <!-- Description -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold; -fx-font-size: 14;">Description</Label>
            <TextArea fx:id="descriptionArea" wrapText="true" prefRowCount="6" style="-fx-control-inner-background: #f9f9f9;"/>
        </VBox>

        <!-- Requirements -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold; -fx-font-size: 14;">Requirements</Label>
            <TextArea fx:id="requirementsArea" wrapText="true" prefRowCount="5" style="-fx-control-inner-background: #f9f9f9;"/>
        </VBox>

        <!-- Skills and Education -->
        <HBox spacing="30">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold;">Required Skills</Label>
                <Label fx:id="requiredSkillsLabel" style="-fx-text-fill: #333; -fx-wrap-text: true;"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold;">Preferred Skills</Label>
                <Label fx:id="preferredSkillsLabel" style="-fx-text-fill: #333; -fx-wrap-text: true;"/>
            </VBox>
        </HBox>

        <HBox spacing="30">
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;">Minimum Education</Label>
                <Label fx:id="educationLabel" style="-fx-text-fill: #333;"/>
            </VBox>
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold;">Experience Required</Label>
                <Label fx:id="experienceLabel" style="-fx-text-fill: #333;"/>
            </VBox>
        </HBox>

        <!-- Action Buttons -->
        <HBox spacing="10" style="-fx-padding: 15; -fx-alignment: CENTER;">
            <Button fx:id="applyButton" text="Apply Now" style="-fx-padding: 10 30; -fx-font-size: 12; -fx-background-color: #4CAF50; -fx-text-fill: white;"/>
            <Button fx:id="backButton" text="Back" style="-fx-padding: 10 30; -fx-font-size: 12;" onAction="#onBack"/>
        </HBox>
    </VBox>
</ScrollPane>
