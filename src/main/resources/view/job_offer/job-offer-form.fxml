<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.job_offer.JobOfferFormController" fitToWidth="true" styleClass="job-offer-form-scroll lms-scroll">
    <VBox alignment="CENTER" spacing="18" styleClass="job-offer-form-shell">
        <VBox fx:id="rootContainer" maxWidth="980.0" spacing="18" styleClass="job-offer-form-panel">
            <HBox spacing="14" alignment="CENTER_LEFT" styleClass="job-offer-form-hero">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="formTitleLabel" text="Create Job Offer" styleClass="job-offer-form-title"/>
                    <Label fx:id="formSubtitleLabel" text="Design an attractive offer that matches the partner dashboard style." wrapText="true" styleClass="job-offer-form-subtitle"/>
                </VBox>
                <Label fx:id="modeBadgeLabel" text="NEW OFFER" styleClass="job-offer-mode-badge"/>
            </HBox>

            <VBox fx:id="partnerSelectionSection" spacing="14" styleClass="job-offer-section" managed="false" visible="false">
                <Label text="Assign to Partner *" styleClass="job-offer-section-title"/>
                <VBox spacing="6">
                    <Label text="Select Partner Account" styleClass="form-label"/>
                    <ComboBox fx:id="partnerCombo" promptText="Choose a partner..." styleClass="lms-input job-offer-input" maxWidth="Infinity"/>
                    <Label text="The offer will be linked to this partner's account. The partner will manage it and see all applications." styleClass="job-offer-form-note" wrapText="true"/>
                </VBox>
            </VBox>

            <VBox spacing="14" styleClass="job-offer-section">
                <Label text="Basic Information" styleClass="job-offer-section-title"/>
                <VBox spacing="6">
                    <Label text="Job Title *" styleClass="form-label"/>
                    <TextField fx:id="titleField" promptText="e.g., Senior Software Engineer" styleClass="lms-input job-offer-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Job Type *" styleClass="form-label"/>
                    <ComboBox fx:id="typeCombo" styleClass="lms-input job-offer-input"/>
                </VBox>
            </VBox>

            <!-- ══ Location + Map ══════════════════════════════════════════════ -->
            <VBox spacing="14" styleClass="job-offer-section">
                <Label text="Location" styleClass="job-offer-section-title"/>
                <Label text="Click on the map or drag the pin to tag the exact location of the job." styleClass="job-offer-form-note" wrapText="true"/>

                <!-- Map WebView -->
                <VBox fx:id="mapContainer" styleClass="job-offer-map-container">
                    <WebView fx:id="locationMapView" prefHeight="320.0" minHeight="280.0"/>
                </VBox>

                <!-- Synced text field (auto-filled by map, user can also type to search) -->
                <VBox spacing="6">
                    <Label text="Selected Location" styleClass="form-label"/>
                    <TextField fx:id="locationField" promptText="e.g., Remote, Tunis, etc. — or click the map above" styleClass="lms-input job-offer-input"/>
                    <Label text="Type an address and press Enter, or click directly on the map." styleClass="job-offer-form-note" wrapText="true"/>
                </VBox>
            </VBox>

            <VBox spacing="14" styleClass="job-offer-section">
                <Label text="Description &amp; Requirements" styleClass="job-offer-section-title"/>
                <VBox spacing="6">
                    <Label text="Description *" styleClass="form-label"/>
                    <TextArea fx:id="descriptionArea" promptText="Describe the job opportunity and responsibilities" wrapText="true" prefRowCount="7" styleClass="lms-input job-offer-text-area"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Requirements" styleClass="form-label"/>
                    <TextArea fx:id="requirementsArea" promptText="List specific requirements for candidates" wrapText="true" prefRowCount="5" styleClass="lms-input job-offer-text-area"/>
                </VBox>
            </VBox>

            <VBox spacing="14" styleClass="job-offer-section">
                <Label text="Skills &amp; Profile" styleClass="job-offer-section-title"/>
                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Required Skills" styleClass="form-label"/>
                        <TextField fx:id="skillsField" promptText="e.g., Java, Spring, SQL" styleClass="lms-input job-offer-input"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Preferred Skills" styleClass="form-label"/>
                        <TextField fx:id="preferredSkillsField" promptText="e.g., Docker, Kubernetes" styleClass="lms-input job-offer-input"/>
                    </VBox>
                </HBox>

                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Minimum Education" styleClass="form-label"/>
                        <ComboBox fx:id="educationCombo" styleClass="lms-input job-offer-input"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Experience (years)" styleClass="form-label"/>
                        <Spinner fx:id="experienceSpinner" styleClass="lms-input job-offer-input job-offer-spinner"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Required Languages" styleClass="form-label"/>
                    <TextField fx:id="languagesField" promptText="e.g., English, French, Arabic" styleClass="lms-input job-offer-input"/>
                </VBox>
            </VBox>

            <VBox spacing="14" styleClass="job-offer-section">
                <Label text="Publication" styleClass="job-offer-section-title"/>
                <HBox spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Date de publication" styleClass="form-label"/>
                        <DatePicker fx:id="publishedDatePicker" promptText="mm/dd/yyyy" styleClass="lms-input job-offer-input job-offer-date-picker"/>
                        <Label fx:id="publishedDateError" text="" styleClass="job-offer-date-error" wrapText="true" managed="false" visible="false"/>
                        <Label text="Laisser vide pour publier immédiatement" styleClass="job-offer-form-note" wrapText="true"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Date d'expiration" styleClass="form-label"/>
                        <DatePicker fx:id="expiresDatePicker" promptText="mm/dd/yyyy" styleClass="lms-input job-offer-input job-offer-date-picker"/>
                        <Label fx:id="expiresDateError" text="" styleClass="job-offer-date-error" wrapText="true" managed="false" visible="false"/>
                        <Label text="Optionnel: date de fin de l'offre" styleClass="job-offer-form-note" wrapText="true"/>
                    </VBox>
                </HBox>
            </VBox>

            <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="job-offer-form-footer">
                <Label text="All fields marked * are required." styleClass="job-offer-form-note"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="cancelButton" text="Cancel" styleClass="ghost-button" onAction="#onCancel"/>
                <Button fx:id="saveButton" text="Create Offer" styleClass="primary-button job-offer-submit-button" onAction="#onSave"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
