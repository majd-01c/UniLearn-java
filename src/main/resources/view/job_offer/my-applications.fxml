<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.job_offer.MyApplicationsController" spacing="15" style="-fx-padding: 20;">
    <VBox.vgrow priority="never">
        <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #f5f5f5; -fx-border-radius: 5;">
            <Label style="-fx-font-weight: bold;">Filter by Status:</Label>
            <ComboBox fx:id="filterStatus" prefWidth="150"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Hyperlink style="-fx-font-size: 12;" text="← Back to Job Offers" onAction="#onBack"/>
        </HBox>
    </VBox.vgrow>

    <VBox.vgrow priority="always">
        <ListView fx:id="applicationListView" VBox.vgrow="ALWAYS" style="-fx-control-inner-background: #ffffff;"/>
    </VBox.vgrow>

    <Label fx:id="noAppsLabel" text="No applications yet. Browse job offers and apply now!" 
            style="-fx-text-fill: #999; -fx-font-size: 14; -fx-alignment: CENTER;" visible="false"/>
</VBox>
