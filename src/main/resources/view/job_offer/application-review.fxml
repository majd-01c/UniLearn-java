<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.job_offer.ApplicationReviewController" fitToWidth="true">
    <VBox spacing="15" style="-fx-padding: 20;">
        <!-- Header -->
        <HBox spacing="20" style="-fx-padding: 15; -fx-background-color: #f5f5f5; -fx-border-radius: 5;">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;">Application Review</Label>
                <HBox spacing="15">
                    <VBox spacing="3">
                        <Label style="-fx-font-size: 11; -fx-text-fill: #666;">Job</Label>
                        <Label fx:id="jobTitleLabel" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label style="-fx-font-size: 11; -fx-text-fill: #666;">Candidate</Label>
                        <Label fx:id="candidateLabel" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label style="-fx-font-size: 11; -fx-text-fill: #666;">Status</Label>
                        <Label fx:id="statusLabel" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!-- Applied Date -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold; -fx-text-fill: #666;">Applied Date</Label>
            <Label fx:id="appliedDateLabel" style="-fx-text-fill: #333;"/>
        </VBox>

        <!-- Candidate Message -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold; -fx-font-size: 14;">Candidate Message</Label>
            <TextArea fx:id="messageArea" wrapText="true" prefRowCount="5" style="-fx-control-inner-background: #f9f9f9;"/>
        </VBox>

        <!-- Score Section -->
        <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #e3f2fd; -fx-border-radius: 5;">
            <Label fx:id="scoreLabel" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            <VBox spacing="5">
                <Label style="-fx-font-size: 12; -fx-font-weight: bold;">Score Breakdown</Label>
                <TextArea fx:id="scoreBreakdownArea" wrapText="true" prefRowCount="4" style="-fx-control-inner-background: #ffffff;"/>
            </VBox>
        </VBox>

        <!-- Action Buttons -->
        <HBox spacing="10" style="-fx-padding: 15; -fx-alignment: CENTER;">
            <Button fx:id="approveButton" text="Approve" style="-fx-padding: 10 30; -fx-font-size: 12; -fx-background-color: #4CAF50; -fx-text-fill: white;" onAction="#onApprove"/>
            <Button fx:id="rejectButton" text="Reject" style="-fx-padding: 10 30; -fx-font-size: 12; -fx-background-color: #f44336; -fx-text-fill: white;" onAction="#onReject"/>
            <Separator orientation="VERTICAL"/>
            <Button fx:id="backButton" text="Back" style="-fx-padding: 10 30; -fx-font-size: 12;" onAction="#onBack"/>
        </HBox>
    </VBox>
</ScrollPane>
