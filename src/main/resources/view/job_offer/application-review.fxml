<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.job_offer.ApplicationReviewController" fitToWidth="true" styleClass="job-offer-scroll">
    <VBox spacing="15" styleClass="job-offer-root">
        <!-- Header -->
        <HBox spacing="20" styleClass="job-offer-surface-card">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Application Review" styleClass="job-offer-page-title"/>
                <HBox spacing="15">
                    <VBox spacing="3">
                        <Label text="Job" styleClass="job-offer-section-label"/>
                        <Label fx:id="jobTitleLabel" styleClass="job-offer-section-title"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="Candidate" styleClass="job-offer-section-label"/>
                        <Label fx:id="candidateLabel" styleClass="job-offer-section-title"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="Status" styleClass="job-offer-section-label"/>
                        <Label fx:id="statusLabel" styleClass="job-offer-status-chip"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!-- Applied Date -->
        <VBox spacing="5" styleClass="job-offer-surface-card">
            <Label text="Applied Date" styleClass="job-offer-section-label"/>
            <Label fx:id="appliedDateLabel" styleClass="job-offer-body-text"/>
        </VBox>

        <!-- Candidate Message -->
        <VBox spacing="5" styleClass="job-offer-surface-card">
            <Label text="Candidate Message" styleClass="job-offer-section-title"/>
            <TextArea fx:id="messageArea" wrapText="true" prefRowCount="5" styleClass="job-offer-readonly-area"/>
        </VBox>

        <!-- Score Section -->
        <VBox spacing="10" styleClass="job-offer-surface-card job-offer-score-card">
            <Label fx:id="scoreLabel" styleClass="job-offer-section-title"/>
            <VBox spacing="5">
                <Label text="Score Breakdown" styleClass="job-offer-section-label"/>
                <TextArea fx:id="scoreBreakdownArea" wrapText="true" prefRowCount="4" styleClass="job-offer-readonly-area"/>
            </VBox>
        </VBox>

        <!-- Action Buttons -->
        <HBox spacing="10" alignment="CENTER" styleClass="job-offer-surface-card">
            <Button fx:id="approveButton" text="Approve" styleClass="primary-button" onAction="#onApprove"/>
            <Button fx:id="rejectButton" text="Reject" styleClass="ghost-button job-offer-danger-button" onAction="#onReject"/>
            <Separator orientation="VERTICAL"/>
            <Button fx:id="backButton" text="Back" styleClass="ghost-button" onAction="#onBack"/>
        </HBox>
    </VBox>
</ScrollPane>
