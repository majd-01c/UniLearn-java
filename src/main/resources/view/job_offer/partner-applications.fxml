<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.job_offer.PartnerApplicationsController" spacing="15" styleClass="job-offer-root">
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="job-offer-surface-card job-offer-toolbar">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label fx:id="pageTitleLabel" text="Applications to Review" styleClass="job-offer-page-title"/>
            <Label fx:id="pageSubtitleLabel" text="Review candidates who applied to your offers." styleClass="job-offer-page-subtitle" wrapText="true"/>
        </VBox>
        <Button fx:id="atsBoardButton" text="⚡ ATS Board" styleClass="primary-button" onAction="#onOpenAtsPipelineBoard"/>
        <Button fx:id="refreshButton" text="Refresh" styleClass="ghost-button" onAction="#onRefresh"/>
        <Button fx:id="backButton" text="Back to Job Offers" styleClass="ghost-button" onAction="#onBack"/>
    </HBox>

    <ScrollPane fx:id="applicationsScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="job-offer-grid-scroll">
        <VBox spacing="14">
            <VBox fx:id="applicationsList" spacing="10" styleClass="job-offer-grid"/>
            <Label fx:id="emptyStateLabel" text="No applications have been submitted to your offers yet." styleClass="job-offer-empty-label" visible="false" managed="false"/>
        </VBox>
    </ScrollPane>
</VBox>